// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id                 Int                 @id @default(autoincrement())
  nom                String
  prenom             String
  email              String              @unique
  motDePasse         String
  role               Role                @default(VENDEUR)
  approvisionnements Approvisionnement[]
  createdAt DateTime @default(now()) 
  mouvements         StockMovement[]
  ventes             Vente[]
  arrivages     Arrivage[]
  actif      Boolean  @default(true)
}


model Categorie {
  id            Int       @id @default(autoincrement())
  nom           String
  description   String?
  date_creation DateTime  @default(now())
  est_active    Boolean   @default(true)
  produits      Produit[]
}

model Produit {
  id            Int             @id @default(autoincrement())
  nom           String
  description   String?
  prixAchat     Float           // Ancien champ "prix", renommé pour plus de clarté
  prixVente     Float           // Nouveau champ obligatoire pour le vendeur
  image         String?         // URL de l'image du produit
  stockMinimum   Int      @default(20) // <--- Ajoute cette ligne (valeur par défaut à 5)
  quantiteStock Int             @default(0)
  categorieId   Int
  fournisseurId Int
  categorie     Categorie       @relation(fields: [categorieId], references: [id])
  fournisseur   Fournisseur     @relation(fields: [fournisseurId], references: [id])
  mouvements    StockMovement[]
  arrivages     Arrivage[]
  enPromotion      Boolean   @default(false)
  dateFinPromo     DateTime?
}
model Fournisseur {
  id                 Int                 @id @default(autoincrement())
  nom                String
  email              String?
  telephone          String?           
  adresse            String?
  contact            String?
  approvisionnements Approvisionnement[]
  produits           Produit[]
  arrivages     Arrivage[]
}

model Vente {
  id        Int      @id @default(autoincrement())
  total     Float
  date      DateTime @default(now())
  articles  Json
  vendeurId Int
  facture   Facture?
  vendeur   User     @relation(fields: [vendeurId], references: [id])
}

model Facture {
  id       Int      @id @default(autoincrement())
  date     DateTime @default(now())
  total    Float
  articles Json
  venteId  Int      @unique
  vente    Vente    @relation(fields: [venteId], references: [id])
}

model Approvisionnement {
  id             Int         @id @default(autoincrement())
  date_reception DateTime    @default(now())
  articles       Json
  etat           String
  magasinierId   Int
  fournisseurId  Int
  fournisseur    Fournisseur @relation(fields: [fournisseurId], references: [id])
  magasinier     User        @relation(fields: [magasinierId], references: [id])
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  type      String
  quantite  Int
  date      DateTime @default(now())
  produitId Int
  userId    Int
  produit   Produit  @relation(fields: [produitId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Rapport {
  id             Int      @id @default(autoincrement())
  type           String
  periode        String
  genere_le      DateTime @default(now())
  statistiques   Json
  top_produits   Json
  ruptures_stock Json
}

enum Role {
  ADMIN
  MANAGER
  VENDEUR
  SAISIE
  MAGASINIER
}


model Arrivage {
  id                Int      @id @default(autoincrement())
  dateArrivee       DateTime @default(now())
  produitId         Int
  produit           Produit  @relation(fields: [produitId], references: [id])
  quantiteRecue     Int
  fournisseurId     Int
  fournisseur       Fournisseur @relation(fields: [fournisseurId], references: [id])
  agentId           Int
  agent             User     @relation(fields: [agentId], references: [id])
}